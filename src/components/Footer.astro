    <div class="flex flex-col items-center justify-between gap-4 text-sm text-apple-muted sm:flex-row">
      <p>&copy; {year} ErgoSum Studio. All rights reserved.</p>
      <div class="flex gap-6">
        <a href="mailto:support@ergosum.studio" class="transition-colors hover:text-apple-text">support@ergosum.studio</a>
        <a href="/support" class="transition-colors hover:text-apple-text">Support</a>
        <a href="/legal/privacy" class="transition-colors hover:text-apple-text">Privacy</a>
        <a href="/legal/terms" class="transition-colors hover:text-apple-text">Terms</a>
      </div>
    </div>
  </div>
</footer>
