---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Support — ErgoSum Studio" description="Get help with ErgoSum Studio apps.">
  <section class="py-24 sm:py-32" data-reveal>
    <div class="mx-auto max-w-2xl px-6">
      <h1 class="text-5xl font-semibold tracking-tight sm:text-6xl">Support</h1>
      <p class="mt-6 text-xl leading-relaxed text-apple-muted">
        We're here to help. Reach us anytime at
        <a href="mailto:support@ergosum.studio" class="text-blue-600 hover:underline">support@ergosum.studio</a>.
      </p>
    </div>
  </section>

  <!-- Midnight Society -->
  <section id="midnight-society" class="scroll-mt-20 py-16" data-reveal>
    <div class="mx-auto max-w-2xl px-6">
      <h2 class="text-3xl font-semibold">Midnight Society</h2>
      <p class="mt-4 text-lg leading-relaxed text-apple-muted">
        Your night-time companion for winding down and reflecting on the day.
      </p>
      <ul class="mt-6 space-y-3 text-apple-muted">
        <li class="flex gap-3">
          <span class="font-medium text-apple-text">Getting started</span>
          — Open the app and follow the evening prompt to begin your first reflection.
        </li>
        <li class="flex gap-3">
          <span class="font-medium text-apple-text">Data &amp; privacy</span>
          — All reflections are stored locally on your device. Nothing leaves your phone.
        </li>
        <li class="flex gap-3">
          <span class="font-medium text-apple-text">Notifications</span>
          — Optional gentle reminders can be configured in Settings. We'll never spam you.
        </li>
      </ul>
    </div>
  </section>

  <!-- Aerie -->
  <section id="aerie" class="scroll-mt-20 py-16" data-reveal>
    <div class="mx-auto max-w-2xl px-6">
      <h2 class="text-3xl font-semibold">Aerie</h2>
      <p class="mt-4 text-lg leading-relaxed text-apple-muted">
        A calm space to organize your thoughts and find clarity.
      </p>
      <ul class="mt-6 space-y-3 text-apple-muted">
        <li class="flex gap-3">
          <span class="font-medium text-apple-text">Getting started</span>
          — Tap the plus button to capture your first thought. No setup required.
        </li>
        <li class="flex gap-3">
          <span class="font-medium text-apple-text">Organization</span>
          — Drag and drop thoughts to reorder, or swipe to archive.
        </li>
        <li class="flex gap-3">
          <span class="font-medium text-apple-text">Data &amp; privacy</span>
          — Your thoughts stay on your device. We never access or collect your content.
        </li>
      </ul>
    </div>
  </section>

  <!-- General contact -->
  <section class="py-24 sm:py-32" data-reveal>
    <div class="mx-auto max-w-2xl px-6 text-center">
      <h2 class="text-3xl font-semibold">Still need help?</h2>
      <p class="mt-4 text-lg text-apple-muted">
        Email us at
        <a href="mailto:support@ergosum.studio" class="text-blue-600 hover:underline">support@ergosum.studio</a>
        and we'll get back to you as soon as we can.
      </p>
    </div>
  </section>
</BaseLayout>
