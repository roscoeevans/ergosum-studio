---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Aerie Support — Ergo Sum" description="Get help with Aerie.">
  <section class="py-24 sm:py-32" data-reveal>
    <div class="mx-auto max-w-2xl px-6">
      <h1 class="text-5xl font-semibold tracking-tight sm:text-6xl">Aerie</h1>
      <p class="mt-6 text-xl leading-relaxed text-apple-muted">
        A calm space to organize your thoughts and find clarity.
      </p>
    </div>
  </section>

  <section class="py-16" data-reveal>
    <div class="mx-auto max-w-2xl px-6">
      <h2 class="text-3xl font-semibold">Getting Started</h2>
      <p class="mt-4 text-lg leading-relaxed text-apple-muted">
        Tap the plus button to capture your first thought. No setup required.
      </p>
    </div>
  </section>

  <section class="py-16" data-reveal>
    <div class="mx-auto max-w-2xl px-6">
      <h2 class="text-3xl font-semibold">Organization</h2>
      <p class="mt-4 text-lg leading-relaxed text-apple-muted">
        Drag and drop thoughts to reorder, or swipe to archive.
      </p>
    </div>
  </section>

  <section class="py-16" data-reveal>
    <div class="mx-auto max-w-2xl px-6">
      <h2 class="text-3xl font-semibold">Data &amp; Privacy</h2>
      <p class="mt-4 text-lg leading-relaxed text-apple-muted">
        Your thoughts stay on your device. We never access or collect your content. For full
        details, see our <a href="/legal/privacy" class="text-blue-600 hover:underline">privacy policy</a>.
      </p>
    </div>
  </section>

  <section class="py-24 sm:py-32" data-reveal>
    <div class="mx-auto max-w-2xl px-6 text-center">
      <h2 class="text-3xl font-semibold">Still need help?</h2>
      <p class="mt-4 text-lg text-apple-muted">
        Email us at
        <a href="mailto:support@ergosum.studio" class="text-blue-600 hover:underline">support@ergosum.studio</a>
        and we'll get back to you as soon as we can.
      </p>
    </div>
  </section>
</BaseLayout>
