---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/Hero.astro";
import FeatureGrid from "../../components/FeatureGrid.astro";

const features = [
  {
    title: "Hidden Roles",
    description: "Every player receives a secret identity with a unique ability. No two nights play out the same.",
    icon: "🎭",
  },
  {
    title: "Local Multiplayer",
    description: "No accounts. No internet. Connect over local WiFi and play face to face — the way it should be.",
    icon: "📡",
  },
  {
    title: "One Night, One Truth",
    description: "Rounds take minutes, not hours. Debate, accuse, vote — and discover who was hiding in plain sight.",
    icon: "🌙",
  },
];
---

<BaseLayout
  title="Midnight Society — Ergo Sum"
  description="A social deduction game for 3–10 players. Hidden roles. Local multiplayer. One night changes everything."
>
  <Hero
    headline="Midnight Society"
    subhead="Not everyone here is what they seem."
    ctaLabel="Download on the App Store"
    ctaHref="#"
    secondaryCtaLabel="Get Support"
    secondaryCtaHref="/support/midnight-society"
  />

  <FeatureGrid features={features} />

  <!-- Designed for callout band -->
  <section class="py-24 sm:py-32">
    <div class="mx-auto max-w-3xl px-6 text-center">
      <div class="space-y-4" data-reveal>
        <p class="text-4xl font-semibold tracking-tight sm:text-5xl">Designed for groups.</p>
      </div>
      <div class="mt-4 space-y-4" data-reveal style="--reveal-delay: 150ms">
        <p class="text-4xl font-semibold tracking-tight text-apple-muted sm:text-5xl">Quick rounds.</p>
      </div>
      <div class="mt-4 space-y-4" data-reveal style="--reveal-delay: 300ms">
        <p class="text-4xl font-semibold tracking-tight text-apple-muted sm:text-5xl">Original roles.</p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-24 sm:py-32" data-reveal>
    <div class="mx-auto max-w-2xl px-6 text-center">
      <h2 class="text-3xl font-semibold">How it works</h2>
      <p class="mt-6 text-lg leading-relaxed text-apple-muted">
        One player hosts. Everyone else joins. Roles are dealt in secret — some belong to
        the Order, others are Marked by the Midnight Society. Night falls, abilities activate,
        and when the lights come up, the real game begins: five minutes to find the truth.
        Choose carefully.
      </p>
    </div>
  </section>

  <!-- Privacy summary -->
  <section class="py-24 sm:py-32" data-reveal>
    <div class="mx-auto max-w-2xl px-6 text-center">
      <h2 class="text-3xl font-semibold">Your data stays yours</h2>
      <p class="mt-6 text-lg leading-relaxed text-apple-muted">
        Midnight Society keeps everything on your device. No accounts, no tracking,
        no data collection. Read our full
        <a href="/legal/privacy" class="text-blue-600 hover:underline">privacy policy</a>.
      </p>
    </div>
  </section>

  <!-- Support CTA -->
  <section class="py-24 sm:py-32" data-reveal>
    <div class="mx-auto max-w-2xl px-6 text-center">
      <h2 class="text-3xl font-semibold">Need help?</h2>
      <p class="mt-4 text-lg text-apple-muted">
        Reach us at
        <a href="mailto:support@ergosum.studio" class="text-blue-600 hover:underline">support@ergosum.studio</a>
        or visit our <a href="/support/midnight-society" class="text-blue-600 hover:underline">support page</a>.
      </p>
    </div>
  </section>
</BaseLayout>
